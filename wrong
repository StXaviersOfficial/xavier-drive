<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
<title>XavierDrive</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet"/>
<style>
:root {
  --bg: #07080f;
  --s1: #0e0f1a;
  --s2: #141522;
  --border: #1f2035;
  --a1: #4f8ef7;
  --a2: #f74f7a;
  --a3: #4ff7b0;
  --text: #e8eaf6;
  --muted: #5c6080;
  --card: #11121e;
  --radius: 14px;
}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;}
body{
  font-family:'Space Grotesk',sans-serif;
  background:var(--bg);color:var(--text);
  min-height:100vh;font-size:15px;
  -webkit-font-smoothing:antialiased;
}

/* grid bg */
body::before{
  content:'';position:fixed;inset:0;
  background-image:
    linear-gradient(rgba(79,142,247,.04) 1px,transparent 1px),
    linear-gradient(90deg,rgba(79,142,247,.04) 1px,transparent 1px);
  background-size:48px 48px;
  pointer-events:none;z-index:0;
}

/* glows */
.g1,.g2{
  position:fixed;border-radius:50%;
  filter:blur(100px);pointer-events:none;z-index:0;
}
.g1{width:500px;height:500px;background:#4f8ef720;top:-150px;left:-100px;}
.g2{width:400px;height:400px;background:#f74f7a18;bottom:-100px;right:-80px;}

/* ── SCREENS ── */
.scr{display:none;position:relative;z-index:1;min-height:100vh;}
.scr.on{display:flex;flex-direction:column;}

/* ══ SPLASH / SETUP ══ */
#s-setup{align-items:center;justify-content:center;padding:24px 16px;}

.logo-mark{
  font-family:'Playfair Display',serif;
  font-size:28px;font-style:italic;
  background:linear-gradient(135deg,var(--a1),var(--a2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
  letter-spacing:-1px;
}

.setup-box{
  width:100%;max-width:460px;
  display:flex;flex-direction:column;gap:20px;
  animation:up .5s ease;
}

.card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:18px;padding:28px;
  display:flex;flex-direction:column;gap:18px;
  box-shadow:0 4px 32px #00000030;
}

.card h2{font-size:19px;font-weight:700;}
.card>p{font-size:13px;color:var(--muted);line-height:1.7;}

.field{display:flex;flex-direction:column;gap:6px;}
.field label{
  font-size:11px;font-weight:600;
  text-transform:uppercase;letter-spacing:.8px;color:var(--muted);
}
.field input,.field select{
  background:var(--s1);
  border:1.5px solid var(--border);
  border-radius:9px;padding:11px 14px;
  font-family:'Space Grotesk',sans-serif;
  font-size:14px;color:var(--text);outline:none;
  transition:border .15s;width:100%;
}
.field input:focus,.field select:focus{border-color:var(--a1);}
.field input::placeholder{color:var(--muted);}

/* steps */
.steps{
  background:var(--s1);border:1px solid var(--border);
  border-radius:10px;padding:16px;
  display:flex;flex-direction:column;gap:10px;
}
.steps .sh{font-size:12px;font-weight:700;color:var(--text);margin-bottom:2px;}
.sr{display:flex;align-items:flex-start;gap:10px;font-size:12px;color:var(--muted);line-height:1.6;}
.sn{
  background:linear-gradient(135deg,var(--a1),var(--a2));
  color:#fff;font-size:10px;font-weight:700;
  width:18px;height:18px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;
}
.steps a{color:var(--a1);text-decoration:none;}

/* tabs */
.tabs{display:flex;gap:3px;background:var(--s1);border-radius:10px;padding:3px;}
.tab{
  flex:1;padding:9px;border:none;border-radius:8px;
  background:transparent;font-family:'Space Grotesk',sans-serif;
  font-size:13px;font-weight:600;cursor:pointer;color:var(--muted);transition:all .15s;
}
.tab.on{background:var(--s2);color:var(--text);box-shadow:0 1px 4px #00000040;}
.tc{display:none;flex-direction:column;gap:14px;}
.tc.on{display:flex;}

/* ── BUTTONS ── */
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:8px;
  padding:12px 20px;border-radius:10px;border:none;
  font-family:'Space Grotesk',sans-serif;font-size:14px;font-weight:600;
  cursor:pointer;transition:all .15s;text-decoration:none;
}
.btn-p{
  background:linear-gradient(135deg,var(--a1),#6a7fff);
  color:#fff;width:100%;
  box-shadow:0 4px 16px #4f8ef730;
}
.btn-p:hover{transform:translateY(-1px);box-shadow:0 8px 24px #4f8ef740;}
.btn-p:active{transform:translateY(0);}
.btn-o{background:transparent;border:1.5px solid var(--border);color:var(--text);}
.btn-o:hover{border-color:var(--a1);color:var(--a1);}
.btn-sm{font-size:12px;padding:8px 14px;}
.btn-d{background:transparent;border:1.5px solid #f74f7a30;color:var(--a2);font-size:12px;padding:8px 12px;}
.btn-d:hover{background:#f74f7a12;}
.btn-dl{background:linear-gradient(135deg,var(--a1),#6a7fff);color:#fff;box-shadow:0 2px 8px #4f8ef730;}
.btn-dl:hover{transform:translateY(-1px);}

/* ══ ROLE SCREEN ══ */
#s-role{align-items:center;justify-content:center;padding:24px 16px;gap:28px;}
.rh{text-align:center;animation:up .4s ease;}
.rh .logo-mark{font-size:22px;display:block;margin-bottom:12px;}
.rh h1{
  font-family:'Playfair Display',serif;
  font-size:40px;letter-spacing:-2px;line-height:1.1;
}
.rh h1 span{
  background:linear-gradient(135deg,var(--a1),var(--a2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  font-style:italic;
}
.rh p{color:var(--muted);font-size:13px;margin-top:8px;}

.rcards{display:flex;gap:14px;flex-wrap:wrap;justify-content:center;}
.rc{
  background:var(--card);border:1.5px solid var(--border);
  border-radius:18px;padding:32px 28px;width:190px;
  cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:14px;
  transition:all .2s;animation:up .5s ease both;
  box-shadow:0 4px 20px #00000020;
}
.rc:nth-child(2){animation-delay:.08s;}
.rc:hover{transform:translateY(-4px);box-shadow:0 16px 40px #00000030;}
.rc:hover.teacher{border-color:var(--a1);}
.rc:hover.student{border-color:var(--a2);}
.ri{width:58px;height:58px;border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:26px;}
.ri.t{background:#4f8ef718;}
.ri.s{background:#f74f7a18;}
.rc h3{font-size:16px;font-weight:700;}
.rc p{font-size:12px;color:var(--muted);text-align:center;line-height:1.5;}

/* PIN MODAL */
.overlay{
  position:fixed;inset:0;
  background:#00000080;backdrop-filter:blur(6px);
  z-index:100;display:none;align-items:center;justify-content:center;padding:20px;
}
.overlay.on{display:flex;}
.modal{
  background:var(--card);border:1px solid var(--border);
  border-radius:18px;padding:28px;width:100%;max-width:340px;
  display:flex;flex-direction:column;gap:16px;
  animation:up .25s ease;
  box-shadow:0 20px 60px #00000050;
}
.modal h3{font-size:17px;font-weight:700;}
.modal p{font-size:13px;color:var(--muted);}
.mbtns{display:flex;gap:10px;}
.mbtns .btn{flex:1;}
.err{font-size:12px;color:var(--a2);display:none;}

/* ══ APP ══ */
#s-app{background:var(--bg);}

nav{
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 20px;
  background:#0e0f1acc;
  border-bottom:1px solid var(--border);
  position:sticky;top:0;z-index:10;
  backdrop-filter:blur(16px);
  gap:12px;flex-wrap:wrap;
}
.nl{display:flex;align-items:center;gap:12px;}
.nlogo{
  font-family:'Playfair Display',serif;
  font-size:19px;font-style:italic;
  background:linear-gradient(135deg,var(--a1),var(--a2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.badge{font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;}
.badge.t{background:#4f8ef718;color:var(--a1);border:1px solid #4f8ef730;}
.badge.s{background:#f74f7a18;color:var(--a2);border:1px solid #f74f7a30;}
.nr{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}

.body{
  max-width:960px;margin:0 auto;
  padding:28px 18px;
  display:flex;flex-direction:column;gap:24px;
}

.ph h2{
  font-family:'Playfair Display',serif;
  font-size:28px;letter-spacing:-1px;
}
.ph p{color:var(--muted);font-size:13px;margin-top:4px;}

/* auth card */
.auth-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:var(--radius);padding:24px;
  display:flex;flex-direction:column;gap:16px;
}
.auth-card h3{font-size:15px;font-weight:700;}
.auth-card p{font-size:13px;color:var(--muted);line-height:1.7;}

/* redirect notice */
.redirect-note{
  background:var(--s1);border:1px solid var(--border);
  border-radius:10px;padding:14px 16px;
  font-size:12px;color:var(--muted);line-height:1.7;
  display:flex;gap:10px;align-items:flex-start;
}
.redirect-note span{font-size:18px;flex-shrink:0;}

/* stats */
.stats{display:flex;gap:12px;flex-wrap:wrap;}
.stat{
  background:var(--card);border:1px solid var(--border);
  border-radius:12px;padding:16px 20px;flex:1;min-width:110px;
}
.sl{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.8px;color:var(--muted);}
.sv{
  font-family:'Playfair Display',serif;
  font-size:34px;
  background:linear-gradient(135deg,var(--a1),var(--a2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  margin-top:4px;
}
.sv.sm{font-family:'Space Grotesk',sans-serif;font-size:13px;font-weight:600;margin-top:8px;word-break:break-all;-webkit-text-fill-color:var(--text);}

/* upload */
.drop{
  border:2px dashed var(--border);border-radius:var(--radius);
  padding:44px 20px;text-align:center;cursor:pointer;
  transition:all .2s;display:flex;flex-direction:column;align-items:center;gap:10px;
  background:var(--card);
}
.drop:hover,.drop.on{border-color:var(--a1);background:#4f8ef708;}
.drop .di{font-size:36px;}
.drop h3{font-size:15px;font-weight:700;}
.drop p{font-size:12px;color:var(--muted);}
#fi{display:none;}

/* progress */
.prog{
  background:var(--card);border:1px solid var(--border);
  border-radius:12px;padding:16px 20px;
  display:none;flex-direction:column;gap:10px;
}
.prog.on{display:flex;}
.pt{display:flex;justify-content:space-between;font-size:12px;}
.pb{height:4px;background:var(--border);border-radius:2px;overflow:hidden;}
.pf{
  height:100%;
  background:linear-gradient(90deg,var(--a1),var(--a2));
  border-radius:2px;transition:width .25s;width:0%;
}

/* section */
.sh2{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:14px;flex-wrap:wrap;gap:10px;
}
.st{font-size:14px;font-weight:700;display:flex;align-items:center;gap:8px;}
.cnt{background:var(--s2);color:var(--muted);font-size:11px;padding:2px 8px;border-radius:20px;}

/* filters */
.fb-row{display:flex;gap:8px;flex-wrap:wrap;align-items:center;}
.fb{
  font-family:'Space Grotesk',sans-serif;
  font-size:12px;padding:6px 14px;border-radius:20px;
  border:1.5px solid var(--border);background:transparent;color:var(--muted);
  cursor:pointer;transition:all .15s;font-weight:500;
}
.fb.on,.fb:hover{border-color:var(--a1);color:var(--a1);background:#4f8ef710;}
.srch{
  background:var(--card);border:1.5px solid var(--border);
  border-radius:8px;padding:7px 14px;
  font-family:'Space Grotesk',sans-serif;font-size:13px;
  color:var(--text);outline:none;transition:border .15s;
  margin-left:auto;width:190px;
}
.srch:focus{border-color:var(--a1);}
.srch::placeholder{color:var(--muted);}

/* grid */
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(190px,1fr));
  gap:14px;
}
.fc{
  background:var(--card);border:1.5px solid var(--border);
  border-radius:var(--radius);padding:18px;
  display:flex;flex-direction:column;gap:12px;
  transition:all .2s;animation:up .3s ease both;
}
.fc:hover{border-color:var(--a1);transform:translateY(-2px);box-shadow:0 8px 24px #4f8ef710;}
.fi2{
  font-size:28px;width:48px;height:48px;border-radius:12px;
  background:var(--s1);display:flex;align-items:center;justify-content:center;
}
.fn{
  font-size:13px;font-weight:600;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;
  word-break:break-all;
}
.fm{display:flex;flex-direction:column;gap:3px;}
.fm span{font-size:11px;color:var(--muted);}
.fa{display:flex;gap:8px;margin-top:auto;}
.fa .btn{flex:1;font-size:12px;padding:8px 10px;}

/* empty / loading */
.empty{grid-column:1/-1;text-align:center;padding:56px 20px;color:var(--muted);}
.empty .ei{font-size:44px;margin-bottom:14px;}
.empty p{font-size:13px;line-height:1.7;}
.loading{
  grid-column:1/-1;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:14px;padding:56px;color:var(--muted);
}
.spin{
  width:28px;height:28px;
  border:2px solid var(--border);border-top-color:var(--a1);
  border-radius:50%;animation:spin .7s linear infinite;
}

/* user pill */
.upill{
  display:flex;align-items:center;gap:8px;
  background:var(--s2);border:1px solid var(--border);
  border-radius:20px;padding:4px 12px 4px 4px;
}
.upill img{width:26px;height:26px;border-radius:50%;}
.upill span{font-size:12px;font-weight:600;}

/* token banner */
.tbanner{
  background:var(--card);border:1px solid var(--border);
  border-radius:var(--radius);padding:24px;
  display:flex;flex-direction:column;gap:14px;
}
.tbanner h3{font-size:15px;font-weight:700;}
.tbanner p{font-size:13px;color:var(--muted);line-height:1.7;}

/* toast */
.toast{
  position:fixed;bottom:24px;left:50%;
  transform:translateX(-50%) translateY(80px);
  background:var(--s2);color:var(--text);
  border:1px solid var(--border);
  border-radius:10px;padding:12px 20px;
  font-size:13px;font-weight:500;z-index:500;
  opacity:0;transition:all .3s;
  white-space:nowrap;max-width:88vw;
  box-shadow:0 8px 32px #00000040;
}
.toast.on{transform:translateX(-50%) translateY(0);opacity:1;}
.toast.ok{border-color:#4ff7b030;color:var(--a3);}
.toast.err{border-color:#f74f7a40;color:var(--a2);}

@keyframes up{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}
@keyframes spin{to{transform:rotate(360deg);}}

@media(max-width:500px){
  nav{padding:12px 14px;}
  .body{padding:18px 14px;}
  .rcards{flex-direction:column;align-items:center;}
  .rc{width:100%;max-width:280px;flex-direction:row;padding:20px;text-align:left;}
  .rc p{display:none;}
  .srch{width:100%;margin-left:0;}
  .card{padding:20px 16px;}
  .rh h1{font-size:32px;}
}
</style>
</head>
<body>
<div class="g1"></div><div class="g2"></div>

<!-- ══ SETUP ══ -->
<div id="s-setup" class="scr on">
  <div class="setup-box">
    <div class="logo-mark">XavierDrive</div>
    <div class="card">
      <h2>First Time Setup</h2>
      <div class="tabs">
        <button class="tab on" onclick="stab('basic')">Basic</button>
        <button class="tab" onclick="stab('oauth')">Google OAuth</button>
      </div>
      <!-- BASIC -->
      <div class="tc on" id="tc-basic">
        <div class="field">
          <label>School / App Name</label>
          <input type="text" id="s-appname" value="St. Xavier's" placeholder="St. Xavier's"/>
        </div>
        <div class="field">
          <label>Drive Folder Name</label>
          <input type="text" id="s-folder" value="Xavier Class Files" placeholder="Xavier Class Files"/>
        </div>
        <div class="field">
          <label>Teacher PIN</label>
          <input type="password" id="s-pin" placeholder="e.g. 1234"/>
        </div>
        <p style="font-size:12px;color:var(--muted)">Students need no PIN — they browse and download freely.</p>
      </div>
      <!-- OAUTH -->
      <div class="tc" id="tc-oauth">
        <div class="steps">
          <p class="sh">Getting your OAuth Client ID</p>
          <div class="sr"><div class="sn">1</div><span>Go to <a href="https://console.cloud.google.com" target="_blank">console.cloud.google.com</a> → New Project</span></div>
          <div class="sr"><div class="sn">2</div><span>Enable <strong style="color:var(--text)">Google Drive API</strong> from API Library</span></div>
          <div class="sr"><div class="sn">3</div><span>Credentials → Create OAuth Client ID → <strong style="color:var(--text)">Web Application</strong></span></div>
          <div class="sr"><div class="sn">4</div><span>Add your GitHub Pages URL to <strong style="color:var(--text)">Authorized JavaScript Origins AND Authorized Redirect URIs</strong></span></div>
          <div class="sr"><div class="sn">5</div><span>Paste Client ID below</span></div>
        </div>
        <div class="field">
          <label>OAuth Client ID</label>
          <input type="text" id="s-cid" placeholder="xxxx.apps.googleusercontent.com"/>
        </div>
        <div class="redirect-note">
          <span>💡</span>
          <span>This app uses <strong style="color:var(--text)">redirect-based sign-in</strong> — when teacher taps Sign In, it opens Google in the real browser (Chrome), then comes back. This works inside APK/WebView.</span>
        </div>
      </div>
      <button class="btn btn-p" onclick="doSetup()">Save & Continue →</button>
    </div>
  </div>
</div>

<!-- ══ ROLE ══ -->
<div id="s-role" class="scr">
  <div class="rh">
    <span class="logo-mark">XavierDrive</span>
    <h1>Who are <span>you?</span></h1>
    <p id="role-sub">Select your role to continue</p>
  </div>
  <div class="rcards">
    <div class="rc teacher" onclick="pick('teacher')">
      <div class="ri t">🎓</div>
      <h3>Teacher</h3>
      <p>Upload & manage class files</p>
    </div>
    <div class="rc student" onclick="pick('student')">
      <div class="ri s">📚</div>
      <h3>Student</h3>
      <p>Browse & download materials</p>
    </div>
  </div>
  <button class="btn btn-o btn-sm" onclick="goSetup()">⚙ Settings</button>
</div>

<!-- PIN MODAL -->
<div class="overlay" id="pin-ov">
  <div class="modal">
    <h3>🔐 Teacher Access</h3>
    <p>Enter the teacher PIN to continue.</p>
    <div class="field">
      <label>PIN</label>
      <input type="password" id="pin-i" placeholder="••••" onkeydown="if(event.key==='Enter')chkPin()"/>
    </div>
    <p class="err" id="pin-err">Wrong PIN. Try again.</p>
    <div class="mbtns">
      <button class="btn btn-o" onclick="closePin()">Cancel</button>
      <button class="btn btn-p" onclick="chkPin()">Enter</button>
    </div>
  </div>
</div>

<!-- ══ APP ══ -->
<div id="s-app" class="scr">
  <nav>
    <div class="nl">
      <div class="nlogo">XavierDrive</div>
      <span class="badge" id="nbadge">Teacher</span>
    </div>
    <div class="nr" id="nr"></div>
  </nav>
  <div class="body">

    <!-- TEACHER -->
    <div id="tv" style="display:none;flex-direction:column;gap:22px">
      <div class="ph"><h2>Teacher Dashboard</h2><p>Upload and manage class files</p></div>

      <!-- Auth card (shown when not signed in) -->
      <div class="auth-card" id="auth-card">
        <h3>🔑 Connect Google Drive</h3>
        <p>Tap the button below. Google will open in your browser — sign in, then come back to the app. This works on both phone and APK.</p>
        <div class="redirect-note">
          <span>📱</span>
          <span>On APK: Chrome will open for sign-in, then automatically return to the app.</span>
        </div>
        <button class="btn btn-p" id="signin-btn" onclick="startAuth()">
          <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" style="width:18px" alt="G"/>
          Sign in with Google
        </button>
        <p id="auth-note" style="font-size:12px;color:var(--muted);display:none"></p>
      </div>

      <!-- Teacher content (shown when signed in) -->
      <div id="tmain" style="display:none;flex-direction:column;gap:22px">
        <div class="stats">
          <div class="stat">
            <div class="sl">Files</div>
            <div class="sv" id="st-n">0</div>
          </div>
          <div class="stat">
            <div class="sl">Folder</div>
            <div class="sv sm" id="st-f">—</div>
          </div>
        </div>

        <div>
          <div class="st" style="margin-bottom:12px">📤 Upload Files</div>
          <div class="drop" id="dz"
               onclick="document.getElementById('fi').click()"
               ondragover="event.preventDefault();this.classList.add('on')"
               ondragleave="this.classList.remove('on')"
               ondrop="onDrop(event)">
            <div class="di">☁️</div>
            <h3>Drop files here or tap to browse</h3>
            <p>PDF, DOCX, PPTX, images, videos — anything</p>
          </div>
          <input type="file" id="fi" multiple onchange="onSel(event)"/>
        </div>

        <div class="prog" id="prog">
          <div class="pt"><span id="pn">Uploading...</span><span id="pp">0%</span></div>
          <div class="pb"><div class="pf" id="pb"></div></div>
        </div>

        <div>
          <div class="sh2">
            <div class="st">📁 Files <span class="cnt" id="tcnt">0</span></div>
            <button class="btn btn-o btn-sm" onclick="loadFiles()">↻ Refresh</button>
          </div>
          <div class="grid" id="tgrid">
            <div class="loading"><div class="spin"></div><span>Loading...</span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- STUDENT -->
    <div id="sv" style="display:none;flex-direction:column;gap:22px">
      <div class="ph">
        <h2>Class Materials</h2>
        <p>Browse and download files from your teacher</p>
      </div>

      <div class="tbanner" id="no-folder" style="display:none">
        <h3>⚠️ Not set up yet</h3>
        <p>Your teacher hasn't uploaded any files yet, or the folder isn't configured. Ask your teacher to log in and upload files first.</p>
      </div>

      <div id="smain" style="display:none;flex-direction:column;gap:16px">
        <div class="fb-row">
          <button class="fb on" onclick="filt('all',this)">All</button>
          <button class="fb" onclick="filt('pdf',this)">PDF</button>
          <button class="fb" onclick="filt('doc',this)">Docs</button>
          <button class="fb" onclick="filt('image',this)">Images</button>
          <button class="fb" onclick="filt('video',this)">Video</button>
          <input class="srch" type="text" placeholder="Search files..." oninput="srch(this.value)"/>
        </div>
        <div class="grid" id="sgrid">
          <div class="loading"><div class="spin"></div><span>Loading...</span></div>
        </div>
      </div>
    </div>

  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ─── CONFIG ──────────────────────────────────────
let C = {};
let role = null;
let token = null;
let fid = null;
let files = [];
let curFilter = 'all';

const SCOPES = 'https://www.googleapis.com/auth/drive';

function lc(){ try{ C = JSON.parse(localStorage.getItem('xd')||'{}'); }catch(e){ C={}; } }
function sc(o){ C={...C,...o}; localStorage.setItem('xd',JSON.stringify(C)); }

// ─── SETUP ───────────────────────────────────────
function stab(t){
  ['basic','oauth'].forEach(k=>{
    document.getElementById('tc-'+k).classList.toggle('on',k===t);
  });
  document.querySelectorAll('.tab').forEach((b,i)=>b.classList.toggle('on',(i===0&&t==='basic')||(i===1&&t==='oauth')));
}

function doSetup(){
  const pin=document.getElementById('s-pin').value.trim();
  const folder=document.getElementById('s-folder').value.trim()||'Xavier Class Files';
  const cid=document.getElementById('s-cid').value.trim();
  const appname=document.getElementById('s-appname').value.trim()||"St. Xavier's";
  if(!pin){toast('Teacher PIN is required','err');return;}
  sc({pin,folder,cid,appname});
  show('s-role');
  document.getElementById('role-sub').textContent = appname + ' — Select your role';
}

function goSetup(){
  lc();
  document.getElementById('s-pin').value=C.pin||'';
  document.getElementById('s-folder').value=C.folder||'Xavier Class Files';
  document.getElementById('s-cid').value=C.cid||'';
  document.getElementById('s-appname').value=C.appname||"St. Xavier's";
  show('s-setup');
}

// ─── SCREENS ─────────────────────────────────────
function show(id){
  document.querySelectorAll('.scr').forEach(s=>s.classList.remove('on'));
  document.getElementById(id).classList.add('on');
}

function init(){
  lc();
  // Handle OAuth redirect callback
  const hash = window.location.hash;
  const params = new URLSearchParams(hash.replace('#',''));
  const at = params.get('access_token');
  if(at){
    // Came back from Google OAuth redirect
    token = at;
    sc({drive_token:at, token_time:Date.now()});
    // Clean URL
    history.replaceState(null,'',window.location.pathname);
    // Restore role
    role = 'teacher';
    enterApp();
    return;
  }

  if(!C.pin){ show('s-setup'); return; }

  // Check for saved valid token
  if(C.drive_token && C.token_time && (Date.now()-C.token_time < 55*60*1000)){
    token = C.drive_token;
  }

  show('s-role');
  document.getElementById('role-sub').textContent = (C.appname||"St. Xavier's") + ' — Select your role';
}

// ─── ROLE ─────────────────────────────────────────
function pick(r){
  if(r==='teacher'){
    document.getElementById('pin-ov').classList.add('on');
    document.getElementById('pin-i').value='';
    document.getElementById('pin-err').style.display='none';
    setTimeout(()=>document.getElementById('pin-i').focus(),100);
  } else {
    role='student'; enterApp();
  }
}
function closePin(){ document.getElementById('pin-ov').classList.remove('on'); }
function chkPin(){
  if(document.getElementById('pin-i').value===C.pin){
    closePin(); role='teacher'; enterApp();
  } else {
    document.getElementById('pin-err').style.display='block';
    document.getElementById('pin-i').value='';
  }
}

// ─── AUTH (REDIRECT FLOW) ────────────────────────
// This opens Google OAuth in the REAL browser, not a popup
// Works perfectly in WebView/APK
function startAuth(){
  if(!C.cid){
    toast('Set your OAuth Client ID in Settings first','err');
    return;
  }
  const redirect = window.location.href.split('#')[0];
  const url = 'https://accounts.google.com/o/oauth2/v2/auth?' + new URLSearchParams({
    client_id: C.cid,
    redirect_uri: redirect,
    response_type: 'token',
    scope: SCOPES,
    include_granted_scopes: 'true',
    prompt: 'select_account'
  });
  // This opens in real browser on Android (bypasses WebView restriction)
  window.location.href = url;
}

function signOut(){
  token=null;
  sc({drive_token:null,token_time:null});
  document.getElementById('auth-card').style.display='';
  document.getElementById('tmain').style.display='none';
  renderNavTeacher(false);
}

// ─── ENTER APP ───────────────────────────────────
function enterApp(){
  show('s-app');
  const badge=document.getElementById('nbadge');
  badge.textContent=role==='teacher'?'🎓 Teacher':'📚 Student';
  badge.className='badge '+(role==='teacher'?'t':'s');
  document.getElementById('st-f').textContent=C.folder||'Xavier Class Files';

  if(role==='teacher'){
    document.getElementById('tv').style.display='flex';
    document.getElementById('sv').style.display='none';
    renderNavTeacher(!!token);
    if(token){
      document.getElementById('auth-card').style.display='none';
      document.getElementById('tmain').style.display='flex';
      ensureFolder().then(()=>loadFiles());
    }
  } else {
    document.getElementById('tv').style.display='none';
    document.getElementById('sv').style.display='flex';
    renderNavStudent();
    loadStudentFiles();
  }
}

function renderNavTeacher(signedin){
  const nr=document.getElementById('nr');
  if(signedin){
    const name=C.user_name||'Teacher';
    const pic=C.user_pic||'';
    nr.innerHTML=`
      <div class="upill">${pic?`<img src="${pic}" alt=""/>`:''}
        <span>${esc(name)}</span></div>
      <button class="btn btn-o btn-sm" onclick="signOut()">Sign out</button>
      <button class="btn btn-o btn-sm" onclick="swRole()">Switch</button>
    `;
  } else {
    nr.innerHTML=`<button class="btn btn-o btn-sm" onclick="swRole()">Switch Role</button>`;
  }
}
function renderNavStudent(){
  document.getElementById('nr').innerHTML=`<button class="btn btn-o btn-sm" onclick="swRole()">Switch Role</button>`;
}
function swRole(){ role=null; show('s-role'); }

// ─── FOLDER ──────────────────────────────────────
async function ensureFolder(){
  if(fid) return fid;
  if(C.folder_id){ fid=C.folder_id; return fid; }
  const name=C.folder||'Xavier Class Files';
  try{
    const q=`mimeType='application/vnd.google-apps.folder' and name='${name}' and trashed=false`;
    const r=await drv('https://www.googleapis.com/drive/v3/files?q='+encodeURIComponent(q)+'&fields=files(id,name)');
    if(r.files?.length){ fid=r.files[0].id; }
    else{
      const cr=await drv('https://www.googleapis.com/drive/v3/files','POST',{name,mimeType:'application/vnd.google-apps.folder'});
      fid=cr.id;
      toast('📁 Folder created','ok');
    }
    // Make folder public
    await drv(`https://www.googleapis.com/drive/v3/files/${fid}/permissions`,'POST',{role:'reader',type:'anyone'}).catch(()=>{});
    sc({folder_id:fid});
  }catch(e){ toast('Folder error: '+e.message,'err'); }
  return fid;
}

// ─── DRIVE FETCH HELPER ──────────────────────────
async function drv(url,method='GET',body=null){
  const opts={method,headers:{Authorization:`Bearer ${token}`}};
  if(body){ opts.headers['Content-Type']='application/json'; opts.body=JSON.stringify(body); }
  const r=await fetch(url,opts);
  if(!r.ok){ const e=await r.json().catch(()=>({})); throw new Error(e.error?.message||r.statusText); }
  if(r.status===204) return {};
  return r.json();
}

// ─── LOAD FILES (TEACHER) ────────────────────────
async function loadFiles(){
  if(!token||!fid) return;
  const g=document.getElementById('tgrid');
  g.innerHTML='<div class="loading"><div class="spin"></div><span>Loading...</span></div>';
  try{
    const r=await drv(`https://www.googleapis.com/drive/v3/files?q=${encodeURIComponent(`'${fid}' in parents and trashed=false`)}&fields=files(id,name,mimeType,size,modifiedTime)&orderBy=modifiedTime+desc`);
    files=r.files||[];
    document.getElementById('tcnt').textContent=files.length;
    document.getElementById('st-n').textContent=files.length;
    renderT(files);
  }catch(e){
    g.innerHTML=`<div class="empty"><div class="ei">❌</div><p>${esc(e.message)}</p></div>`;
  }
}

function renderT(fs){
  const g=document.getElementById('tgrid');
  if(!fs.length){ g.innerHTML='<div class="empty"><div class="ei">📭</div><p>No files yet.<br/>Upload something above!</p></div>'; return; }
  g.innerHTML=fs.map((f,i)=>`
    <div class="fc" style="animation-delay:${i*.04}s">
      <div class="fi2">${ico(f.mimeType,f.name)}</div>
      <div class="fn" title="${esc(f.name)}">${esc(f.name)}</div>
      <div class="fm"><span>${sz(f.size)}</span><span>${dt(f.modifiedTime)}</span></div>
      <div class="fa">
        <button class="btn btn-dl" onclick="dlFile('${f.id}','${esc2(f.name)}')">⬇</button>
        <button class="btn btn-d" onclick="delFile('${f.id}','${esc2(f.name)}')">🗑</button>
      </div>
    </div>`).join('');
}

// ─── LOAD FILES (STUDENT — PUBLIC) ───────────────
async function loadStudentFiles(){
  const folderid=C.folder_id;
  if(!folderid){
    document.getElementById('no-folder').style.display='';
    document.getElementById('smain').style.display='none';
    return;
  }
  document.getElementById('no-folder').style.display='none';
  document.getElementById('smain').style.display='flex';

  const g=document.getElementById('sgrid');
  g.innerHTML='<div class="loading"><div class="spin"></div><span>Loading...</span></div>';

  try{
    // Public folder — no auth needed
    // Use saved token if still valid for better experience
    const headers={};
    if(C.drive_token&&C.token_time&&(Date.now()-C.token_time<55*60*1000)){
      headers['Authorization']=`Bearer ${C.drive_token}`;
    }

    const url=`https://www.googleapis.com/drive/v3/files?q=${encodeURIComponent(`'${folderid}' in parents and trashed=false`)}&fields=files(id,name,mimeType,size,modifiedTime)&orderBy=modifiedTime+desc`;
    const r=await fetch(url,{headers});
    const data=await r.json();

    if(data.error){
      g.innerHTML='<div class="empty"><div class="ei">🔒</div><p>Files not accessible.<br/>Ask teacher to re-upload or re-login.</p></div>';
      return;
    }
    files=data.files||[];
    renderS(files);
  }catch(e){
    g.innerHTML=`<div class="empty"><div class="ei">❌</div><p>${esc(e.message)}</p></div>`;
  }
}

function renderS(fs){
  const g=document.getElementById('sgrid');
  if(!fs.length){ g.innerHTML='<div class="empty"><div class="ei">📂</div><p>No files yet.<br/>Check back later.</p></div>'; return; }
  g.innerHTML=fs.map((f,i)=>`
    <div class="fc" style="animation-delay:${i*.04}s">
      <div class="fi2">${ico(f.mimeType,f.name)}</div>
      <div class="fn" title="${esc(f.name)}">${esc(f.name)}</div>
      <div class="fm"><span>${sz(f.size)}</span><span>${dt(f.modifiedTime)}</span></div>
      <div class="fa">
        <button class="btn btn-dl" onclick="dlFile('${f.id}','${esc2(f.name)}')">⬇ Download</button>
      </div>
    </div>`).join('');
}

// ─── FILTER / SEARCH ─────────────────────────────
function filt(type,btn){
  document.querySelectorAll('.fb').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on'); curFilter=type; applyFS();
}
function srch(q){ applyFS(q); }
function applyFS(q=document.querySelector('.srch')?.value||''){
  let fs=files;
  if(curFilter!=='all') fs=fs.filter(f=>{
    const m=f.mimeType||'',n=f.name.toLowerCase();
    if(curFilter==='pdf') return m.includes('pdf')||n.endsWith('.pdf');
    if(curFilter==='doc') return m.includes('word')||m.includes('document')||n.match(/\.(docx?|pptx?|txt)$/);
    if(curFilter==='image') return m.startsWith('image/');
    if(curFilter==='video') return m.startsWith('video/');
    return true;
  });
  if(q) fs=fs.filter(f=>f.name.toLowerCase().includes(q.toLowerCase()));
  if(role==='student') renderS(fs); else renderT(fs);
}

// ─── UPLOAD ──────────────────────────────────────
function onDrop(e){
  e.preventDefault();
  document.getElementById('dz').classList.remove('on');
  upAll([...e.dataTransfer.files]);
}
function onSel(e){ upAll([...e.target.files]); e.target.value=''; }
async function upAll(fs){
  if(!token){toast('Sign in first','err');return;}
  await ensureFolder();
  for(const f of fs) await upOne(f);
  loadFiles();
}

function upOne(file){
  return new Promise(res=>{
    const prog=document.getElementById('prog');
    const bar=document.getElementById('pb');
    const pct=document.getElementById('pp');
    const fn=document.getElementById('pn');
    prog.classList.add('on');
    fn.textContent=file.name;
    bar.style.width='0%'; pct.textContent='0%';

    const meta={name:file.name,parents:[fid]};
    const form=new FormData();
    form.append('metadata',new Blob([JSON.stringify(meta)],{type:'application/json'}));
    form.append('file',file);

    const xhr=new XMLHttpRequest();
    xhr.open('POST','https://www.googleapis.com/upload/drive/v3/files?uploadType=multipart');
    xhr.setRequestHeader('Authorization',`Bearer ${token}`);
    xhr.upload.onprogress=e=>{
      if(e.lengthComputable){const p=Math.round(e.loaded/e.total*100);bar.style.width=p+'%';pct.textContent=p+'%';}
    };
    xhr.onload=()=>{
      prog.classList.remove('on');
      if(xhr.status===200){
        toast(`✅ ${file.name}`,'ok');
        const fd=JSON.parse(xhr.responseText);
        mkPublic(fd.id);
      } else toast(`❌ Failed: ${file.name}`,'err');
      res();
    };
    xhr.onerror=()=>{prog.classList.remove('on');toast('Upload error','err');res();};
    xhr.send(form);
  });
}

async function mkPublic(fileId){
  try{
    await fetch(`https://www.googleapis.com/drive/v3/files/${fileId}/permissions`,{
      method:'POST',
      headers:{Authorization:`Bearer ${token}`,'Content-Type':'application/json'},
      body:JSON.stringify({role:'reader',type:'anyone'})
    });
  }catch(e){}
}

// ─── DOWNLOAD ────────────────────────────────────
async function dlFile(id,name){
  toast(`⬇ ${name}`);
  try{
    const headers={};
    if(token) headers['Authorization']=`Bearer ${token}`;
    else if(C.drive_token&&(Date.now()-C.token_time<55*60*1000)) headers['Authorization']=`Bearer ${C.drive_token}`;

    const r=await fetch(`https://www.googleapis.com/drive/v3/files/${id}?alt=media`,{headers});
    if(!r.ok) throw new Error('not ok');
    const blob=await r.blob();
    const a=document.createElement('a');
    a.href=URL.createObjectURL(blob);
    a.download=name; a.click();
    URL.revokeObjectURL(a.href);
    toast(`✅ Downloaded: ${name}`,'ok');
  }catch(e){
    // Fallback to Drive direct link
    window.open(`https://drive.google.com/uc?export=download&id=${id}`,'_blank');
  }
}

// ─── DELETE ──────────────────────────────────────
async function delFile(id,name){
  if(!confirm(`Delete "${name}"?`)) return;
  try{
    await drv(`https://www.googleapis.com/drive/v3/files/${id}`,'DELETE');
    toast(`🗑 Deleted`,'ok'); loadFiles();
  }catch(e){ toast('Delete failed','err'); }
}

// ─── HELPERS ─────────────────────────────────────
function ico(m,n){
  m=m||'';n=(n||'').toLowerCase();
  if(m.includes('pdf')||n.endsWith('.pdf')) return '📄';
  if(m.includes('word')||n.endsWith('.docx')) return '📝';
  if(m.includes('presentation')||n.endsWith('.pptx')) return '📊';
  if(m.includes('spreadsheet')||n.endsWith('.xlsx')) return '📈';
  if(m.startsWith('image/')) return '🖼️';
  if(m.startsWith('video/')) return '🎥';
  if(m.startsWith('audio/')) return '🎵';
  if(m.includes('zip')) return '🗜️';
  return '📁';
}
function sz(b){
  if(!b) return '—'; b=parseInt(b);
  if(b<1024) return b+' B';
  if(b<1048576) return (b/1024).toFixed(1)+' KB';
  if(b<1073741824) return (b/1048576).toFixed(1)+' MB';
  return (b/1073741824).toFixed(1)+' GB';
}
function dt(d){ if(!d) return '—'; return new Date(d).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}); }
function esc(s){ return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function esc2(s){ return (s||'').replace(/'/g,"\\'").replace(/"/g,'\\"'); }

let _tt;
function toast(msg,type=''){
  const t=document.getElementById('toast');
  t.textContent=msg; t.className='toast on '+(type||'');
  clearTimeout(_tt); _tt=setTimeout(()=>t.classList.remove('on'),3000);
}

window.onload=init;
</script>
</body>
